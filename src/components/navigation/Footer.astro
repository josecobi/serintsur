---
/*
  Footer — navy background, four columns, legal bar.
  Section headings, common labels, and service names come from `getStrings`.
  Slugs stay Spanish across all locales until a slug-translation strategy lands.

  Address/phone/email/CIF are hardcoded from the company record in CLAUDE.md.
  When Sanity siteSettings becomes load-bearing, accept an optional prop and
  merge over these defaults.
*/
import Container from "../ui/Container.astro";
import { getLocaleFromUrl, getStrings, type Locale } from "../../lib/i18n";

export interface Props {
  currentLocale?: Locale;
  logoUrl?: string;
}

const { currentLocale: localeProp, logoUrl } = Astro.props;
const currentLocale: Locale = localeProp ?? getLocaleFromUrl(Astro.url);
const t = getStrings(currentLocale);

const localePath = (slug: string) => `/${currentLocale}/${slug}${slug ? "/" : ""}`;

const serviceLinks = [
  { slug: "servicios/reformas", label: t.services.renovation },
  { slug: "servicios/rehabilitacion", label: t.services.facade },
  { slug: "servicios/construccion", label: t.services.construction },
  { slug: "servicios/mantenimiento", label: t.services.maintenance },
];

const companyLinks = [
  { slug: "sobre-nosotros", label: t.nav.about },
  { slug: "proyectos", label: t.nav.projects },
  { slug: "presupuesto", label: t.common.requestQuote },
  { slug: "contacto", label: t.nav.contact },
];

// TODO(content): add footer.legalNotice / privacyPolicy / cookies as distinct slugs
// if/when those pages exist. For now they point at root slugs that may 404.
const legalLinks = [
  { slug: "aviso-legal", label: t.footer.legalNotice },
  { slug: "privacidad", label: t.footer.privacyPolicy },
  { slug: "cookies", label: t.footer.cookies },
];

const whatsappHref = "https://wa.me/34655634800";
const phoneDisplay = "+34 655 634 800";
const phoneHref = "tel:+34655634800";
const emailDisplay = "jlcobano@serintsur.com";
const emailHref = "mailto:jlcobano@serintsur.com";
const addressLines = [
  "Avda. Alcalde Cantos Ropero, 104, Nave 6",
  "11407 Jerez de la Frontera, Cádiz",
];
const year = new Date().getFullYear();
---

<footer class="bg-navy text-white" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">{t.site.name}</h2>

  <Container width="wide" padY="lg">
    <div class="grid gap-10 md:grid-cols-12 md:gap-8">
      <!-- Brand column -->
      <div class="md:col-span-5 lg:col-span-4">
        <a
          href={localePath("")}
          class="inline-flex items-center gap-2 text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-4 rounded-sm"
          aria-label={t.site.name}
        >
          {logoUrl ? (
            <img src={logoUrl} alt={t.site.name} class="h-20 w-auto" width="440" height="80" />
          ) : (
            <>
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-white text-navy font-display text-xl font-bold">
                S
              </span>
              <span class="font-display text-xl font-bold tracking-tight">Serintsur</span>
            </>
          )}
        </a>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-white/70">
          {t.site.tagline}
        </p>

        <div class="mt-6 flex items-center gap-3">
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t.common.chatWhatsApp}
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-white/15 text-white/80 transition-all hover:-translate-y-0.5 hover:border-orange hover:bg-orange hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </a>
          <a
            href={emailHref}
            aria-label={emailDisplay}
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-white/15 text-white/80 transition-all hover:-translate-y-0.5 hover:border-orange hover:bg-orange hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="m3 7 9 6 9-6"/>
            </svg>
          </a>
          <a
            href={phoneHref}
            aria-label={phoneDisplay}
            class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-white/15 text-white/80 transition-all hover:-translate-y-0.5 hover:border-orange hover:bg-orange hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div class="md:col-span-3 lg:col-span-2">
        <h3 class="font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange-light">
          {t.nav.services}
        </h3>
        <ul class="mt-4 space-y-3">
          {
            serviceLinks.map((item) => (
              <li>
                <a
                  href={localePath(item.slug)}
                  class="inline-flex text-sm text-white/75 transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company column -->
      <div class="md:col-span-4 lg:col-span-2">
        <h3 class="font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange-light">
          {t.site.name.split(" ")[0]}
        </h3>
        <ul class="mt-4 space-y-3">
          {
            companyLinks.map((item) => (
              <li>
                <a
                  href={localePath(item.slug)}
                  class="inline-flex text-sm text-white/75 transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact column -->
      <div class="md:col-span-12 lg:col-span-4">
        <h3 class="font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange-light">
          {t.nav.contact}
        </h3>
        <address class="mt-4 not-italic text-sm text-white/75 space-y-1">
          {addressLines.map((line) => <div>{line}</div>)}
        </address>
        <dl class="mt-4 space-y-2 text-sm">
          <div class="flex items-center gap-2">
            <dt class="sr-only">{t.footer.phone}</dt>
            <dd>
              <a href={phoneHref} class="font-tech text-white transition-colors hover:text-orange-light focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm">
                {phoneDisplay}
              </a>
            </dd>
          </div>
          <div class="flex items-center gap-2">
            <dt class="sr-only">{t.footer.email}</dt>
            <dd>
              <a href={emailHref} class="text-white transition-colors hover:text-orange-light focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm">
                {emailDisplay}
              </a>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </Container>

  <!-- Legal bar -->
  <div class="border-t border-white/10">
    <Container width="wide">
      <div class="flex flex-col items-start gap-3 py-5 text-xs text-white/60 md:flex-row md:items-center md:justify-between">
        <p>
          © {year} Serintsur Multiservicios S.L. · {t.footer.rights}
          <span class="mx-2 hidden text-white/25 md:inline">·</span>
          <span class="block md:inline">
            CIF: <span class="font-tech">B11945391</span>
          </span>
        </p>
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-1">
          {
            legalLinks.map((item) => (
              <li>
                <a
                  href={localePath(item.slug)}
                  class="transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </Container>
  </div>
</footer>

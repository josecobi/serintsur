---
/*
  ClientLogos — infinite horizontal marquee.
  The track contains the logo list twice so a translateX(-50%) animation
  loops seamlessly. Respects prefers-reduced-motion (pauses).
  Pauses on hover/focus within for accessibility.

  If a logo has no `src`, the `name` renders as a text wordmark fallback —
  useful until Jorge delivers SVGs.
*/
import Container from "../ui/Container.astro";

export interface ClientLogo {
  name: string;
  src?: string;
  alt?: string;
  href?: string;
  /** "light" = white-on-transparent logo; applies invert so it's visible on light backgrounds */
  variant?: "light" | "dark";
  /** When true, render the client name as a caption below the logo (useful for hard-to-read marks). */
  showName?: boolean;
}

export interface Props {
  heading?: string;
  logos: ClientLogo[];
  speed?: "slow" | "normal" | "fast";
  class?: string;
}

const { heading, logos, speed = "normal", class: className = "" } = Astro.props;

const durationMap = {
  slow: "60s",
  normal: "40s",
  fast: "25s",
};

// Duplicate the list so the -50% translate animation loops seamlessly
const items = [...logos, ...logos];
---

<section class:list={["relative overflow-hidden bg-offwhite", className]} aria-label={heading ?? "Clientes y colaboradores"}>
  <Container width="wide" padY="md">
    {
      heading && (
        <p class="mb-8 text-center font-sans text-xs font-semibold uppercase tracking-[0.12em] text-sand-500">
          {heading}
        </p>
      )
    }

    <div class="marquee group relative">
      <ul
        class="marquee__track flex w-max items-center gap-12 md:gap-16"
        style={`--marquee-duration: ${durationMap[speed]}`}
      >
        {
          items.map((logo, i) => {
            const baseImg = [
              "h-10 md:h-12 w-auto object-contain grayscale opacity-60 transition-all duration-300",
              logo.variant === "light" ? "invert" : "",
            ].filter(Boolean).join(" ");
            const interactive = !!logo.href;
            const showCaption = !!logo.src && !!logo.showName;
            const captionClass = [
              "font-sans text-[11px] font-medium uppercase tracking-wide text-sand-500 transition-colors md:text-xs",
              interactive ? "group-hover/logo:text-navy" : "",
            ].filter(Boolean).join(" ");

            const inner = logo.src ? (
              showCaption ? (
                <span class="flex flex-col items-center gap-1.5">
                  <img
                    src={logo.src}
                    alt={logo.alt ?? logo.name}
                    class={interactive ? `${baseImg} group-hover/logo:grayscale-0 group-hover/logo:opacity-100` : baseImg}
                    loading="lazy"
                    decoding="async"
                  />
                  <span class={captionClass}>{logo.name}</span>
                </span>
              ) : (
                <img
                  src={logo.src}
                  alt={logo.alt ?? logo.name}
                  class={interactive ? `${baseImg} group-hover/logo:grayscale-0 group-hover/logo:opacity-100` : baseImg}
                  loading="lazy"
                  decoding="async"
                />
              )
            ) : (
              <span
                class:list={[
                  "font-display text-xl font-bold uppercase tracking-wide text-sand-500 md:text-2xl",
                  interactive && "transition-colors group-hover/logo:text-navy",
                ]}
              >
                {logo.name}
              </span>
            );

            return (
              <li class="shrink-0" aria-hidden={i >= logos.length ? "true" : undefined}>
                {interactive ? (
                  <a
                    href={logo.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group/logo block"
                    aria-label={logo.name}
                  >
                    {inner}
                  </a>
                ) : (
                  inner
                )}
              </li>
            );
          })
        }
      </ul>
    </div>
  </Container>
</section>

<style>
  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      /* -50% because the track contains the list twice; one loop = one full list */
      transform: translateX(-50%);
    }
  }

  .marquee__track {
    animation: marquee-scroll var(--marquee-duration, 40s) linear infinite;
    will-change: transform;
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-font-smoothing: subpixel-antialiased;
  }

  .marquee:hover .marquee__track,
  .marquee:focus-within .marquee__track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>

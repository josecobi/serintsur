---
/*
  HeroSection — full-bleed hero. Mobile-first: content stacks with a navy
  gradient on top of the image. Desktop uses a left-weighted gradient so the
  photography on the right breathes while the text remains readable.

  Image handling: accepts a plain `image` prop for now. Once Sanity is wired,
  switch to Astro's <Image> or Sanity's CDN URL builder and add srcset/sizes.
  Mark as LCP: fetchpriority="high", loading="eager", no lazy attribute.
*/
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";

export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  image?: { src: string; alt: string };
  stats?: { value: string; label: string }[];
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  primaryCta,
  secondaryCta,
  image,
  stats = [],
  class: className = "",
} = Astro.props;
---

<section
  class:list={[
    "relative isolate overflow-hidden bg-navy text-white",
    className,
  ]}
  aria-labelledby="hero-title"
>
  <!-- Background media: image if provided, otherwise a textured navy gradient -->
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    {
      image ? (
        <img
          src={image.src}
          alt={image.alt}
          class="h-full w-full object-cover"
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
      ) : (
        <div class="h-full w-full bg-[radial-gradient(circle_at_70%_30%,theme(colors.navy-light)_0%,theme(colors.navy)_50%,theme(colors.navy-dark)_100%)]" />
      )
    }
    <!-- Navy gradient for legibility: stronger on the left where content sits -->
    <div class="absolute inset-0 bg-gradient-to-r from-navy-dark/95 via-navy/75 to-navy/25 md:from-navy-dark/90 md:via-navy/60 md:to-transparent"></div>
    <!-- Subtle noise/grain via SVG would be nice — skipping for now to keep bundle light -->
  </div>

  <Container width="wide" padY="xl">
    <div class="flex min-h-[calc(100svh-5rem)] flex-col justify-center gap-8 py-8 md:min-h-[640px] md:max-w-2xl md:py-16">
      <div class="flex flex-col gap-5">
        {
          eyebrow && (
            <div class="flex items-center gap-3">
              <span class="h-[3px] w-10 rounded-sm bg-orange" aria-hidden="true" />
              <span class="font-sans text-xs font-semibold uppercase tracking-[0.1em] text-orange-light">
                {eyebrow}
              </span>
            </div>
          )
        }

        <h1
          id="hero-title"
          class="font-display text-display font-bold text-white"
        >
          {title}
        </h1>

        {
          subtitle && (
            <p class="max-w-xl text-lg leading-relaxed text-white/80 md:text-xl">
              {subtitle}
            </p>
          )
        }
      </div>

      {
        (primaryCta || secondaryCta) && (
          <div class="flex flex-wrap items-center gap-3">
            {primaryCta && (
              <Button variant="primary" size="lg" href={primaryCta.href}>
                {primaryCta.label}
                <svg slot="icon-right" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14"/>
                  <path d="m12 5 7 7-7 7"/>
                </svg>
              </Button>
            )}
            {secondaryCta && (
              <Button
                variant="outline"
                size="lg"
                href={secondaryCta.href}
                class="border-white/40 text-white hover:bg-white hover:text-navy"
              >
                {secondaryCta.label}
              </Button>
            )}
          </div>
        )
      }

      {
        stats.length > 0 && (
          <dl class="mt-4 flex flex-wrap items-baseline gap-x-8 gap-y-4 border-t border-white/15 pt-6">
            {stats.map((stat) => (
              <div class="flex items-baseline gap-2">
                <dt class="font-display text-2xl font-bold text-orange-light">
                  {stat.value}
                </dt>
                <dd class="text-sm text-white/70">{stat.label}</dd>
              </div>
            ))}
          </dl>
        )
      }
    </div>
  </Container>

  <!-- Scroll cue (desktop only) -->
  <div
    class="pointer-events-none absolute bottom-8 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 text-white/50 md:flex"
    aria-hidden="true"
  >
    <span class="text-[0.625rem] font-semibold uppercase tracking-[0.2em]">Scroll</span>
    <svg width="14" height="20" viewBox="0 0 14 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <rect x="1" y="1" width="12" height="18" rx="6"/>
      <line x1="7" y1="5" x2="7" y2="9">
        <animate attributeName="y1" values="5;8;5" dur="2s" repeatCount="indefinite"/>
        <animate attributeName="y2" values="9;12;9" dur="2s" repeatCount="indefinite"/>
      </line>
    </svg>
  </div>
</section>

---
/*
  Home page (Spanish).

  Designer pass: wires Backend's Sanity data into the design-system sections
  (Hero → Stats → Services → Projects → Clients → CTA). Every fetch is wrapped
  with a .catch so a Sanity outage can't blank the page — each section
  gracefully hides if its data is empty.
*/
import BaseLayout from '~/layouts/BaseLayout.astro';
import HeroSection from '~/components/sections/HeroSection.astro';
import StatsSection, { type Stat } from '~/components/sections/StatsSection.astro';
import ServicesGrid, {
  type Service as ServiceCard,
  type ServiceIcon,
} from '~/components/sections/ServicesGrid.astro';
import ProjectsShowcase, {
  type FeaturedProject,
} from '~/components/sections/ProjectsShowcase.astro';
import ClientLogos, {
  type ClientLogo as ClientLogoData,
} from '~/components/sections/ClientLogos.astro';
import CtaBanner from '~/components/sections/CtaBanner.astro';
import { projectsToCardData } from '~/components/project-filter/mapper';
import { getStrings } from '~/lib/i18n';
import {
  getActiveClientLogos,
  getActiveServices,
  getFeaturedProjects,
  getSiteSettings,
  pickLocale,
  safeImageUrl,
} from '~/lib/sanity';

const locale = 'es';
const t = getStrings(locale);

const [siteSettings, services, featuredProjectsRaw, clientLogos] =
  await Promise.all([
    getSiteSettings().catch((e) => {
      console.error('[home] siteSettings fetch failed:', e);
      return null;
    }),
    getActiveServices().catch((e) => {
      console.error('[home] services fetch failed:', e);
      return [];
    }),
    getFeaturedProjects(4).catch((e) => {
      console.error('[home] featured projects fetch failed:', e);
      return [];
    }),
    getActiveClientLogos().catch((e) => {
      console.error('[home] client logos fetch failed:', e);
      return [];
    }),
  ]);

const featuredProjectsCardData = projectsToCardData(featuredProjectsRaw, locale);
const tagline = pickLocale(siteSettings?.tagline, locale) ?? t.site.tagline;
const stats = siteSettings?.stats;
const heroImageUrl = safeImageUrl(siteSettings?.heroImage, 1600);
const heroImageAlt = siteSettings?.heroImage?.alt ?? 'Serintsur Multiservicios';

// ─── Map the service icon field onto our ServiceIcon keys ──
// Sanity's `icon` field is a free-form string; we fall back to matching the
// service slug (e.g. `servicios/reformas` → `reformas`) so design works even
// before the CMS content has the icon column filled in.
const ICON_KEYS: ServiceIcon[] = [
  'reformas',
  'rehabilitacion',
  'construccion',
  'mantenimiento',
];

function resolveServiceIcon(
  icon: string | undefined,
  slug: string,
): ServiceIcon {
  if (icon && (ICON_KEYS as string[]).includes(icon)) return icon as ServiceIcon;
  const slugTail = slug.split('/').pop() ?? slug;
  if ((ICON_KEYS as string[]).includes(slugTail)) return slugTail as ServiceIcon;
  return 'default';
}

// ─── Shape data for each section ──
const serviceCards: ServiceCard[] = services.map((service) => ({
  title: pickLocale(service.title, locale) ?? '',
  description: pickLocale(service.description, locale) ?? '',
  href: `/${locale}/servicios/${service.slug.current}/`,
  icon: resolveServiceIcon(service.icon, service.slug.current),
  linkLabel: t.common.readMore,
}));

const featuredProjectsForShowcase: FeaturedProject[] = featuredProjectsCardData
  .filter((p) => !!p.imageUrl)
  .map((p) => ({
    title: p.title,
    category: p.serviceTitle ?? t.common.service,
    location: [p.city, p.province].filter(Boolean).join(', '),
    year: p.year ? String(p.year) : undefined,
    imageSrc: p.imageUrl!,
    imageAlt: p.imageAlt ?? p.title,
    href: `/${locale}/proyectos/${p.slug}/`,
  }));

const clientLogoData: ClientLogoData[] = clientLogos.map((c) => ({
  name: c.name,
  src: safeImageUrl(c.logo, 320),
  alt: c.name,
  href: c.url,
  variant: c.logoVariant === 'light' ? 'light' : undefined,
  showName: c.showName,
  size: c.logoSize,
}));

const heroStats = stats
  ? [
      stats.projectsCompleted !== undefined && {
        value: `+${stats.projectsCompleted}`,
        label: 'Proyectos',
      },
      stats.yearsExperience !== undefined && {
        value: `${stats.yearsExperience}`,
        label: 'Años',
      },
      stats.teamSize !== undefined && {
        value: `${stats.teamSize}`,
        label: 'Profesionales',
      },
    ].filter(Boolean) as { value: string; label: string }[]
  : [];

const statsForBand: Stat[] = [];
if (stats) {
  if (stats.projectsCompleted !== undefined) {
    statsForBand.push({
      value: stats.projectsCompleted,
      suffix: '+',
      label: 'Proyectos completados',
    });
  }
  if (stats.yearsExperience !== undefined) {
    statsForBand.push({ value: stats.yearsExperience, label: 'Años de experiencia' });
  }
  if (stats.teamSize !== undefined) {
    statsForBand.push({ value: stats.teamSize, label: 'Profesionales' });
  }
  if (stats.citiesCovered !== undefined) {
    statsForBand.push({ value: stats.citiesCovered, label: 'Provincias' });
  }
}
---

<BaseLayout
  title={`${t.site.name} — ${tagline}`}
  description={t.site.descriptionShort}
  lang={locale}
>
  <HeroSection
    eyebrow="Serintsur Multiservicios S.L."
    title="Construimos y rehabilitamos espacios que perduran"
    subtitle={tagline}
    primaryCta={{ label: t.common.requestQuote, href: `/${locale}/presupuesto/` }}
    secondaryCta={{ label: t.common.seeProjects, href: `/${locale}/proyectos/` }}
    stats={heroStats}
    image={heroImageUrl ? { src: heroImageUrl, alt: heroImageAlt } : undefined}
  />

  {serviceCards.length > 0 && (
    <ServicesGrid
      heading={{
        eyebrow: 'Nuestros servicios',
        title: 'Qué hacemos',
        subtitle:
          'De la rehabilitación de fachadas a la construcción de villas a medida, cubrimos todo el ciclo de edificación en Cádiz, Málaga y Sevilla.',
      }}
      services={serviceCards}
      linkLabelDefault={t.common.readMore}
      background="offwhite"
    />
  )}

  {featuredProjectsForShowcase.length > 0 && (
    <ProjectsShowcase
      heading={{
        eyebrow: 'Obra reciente',
        title: 'Proyectos destacados',
        subtitle:
          'Una selección de obras entregadas para administraciones, bodegas, hoteles y promotores.',
      }}
      projects={featuredProjectsForShowcase}
      viewAll={{ label: t.common.seeAll, href: `/${locale}/proyectos/` }}
      background="white"
    />
  )}

  {statsForBand.length > 0 && (
    <StatsSection
      heading={{
        eyebrow: 'Trayectoria',
        title: 'Números que respaldan el oficio',
      }}
      stats={statsForBand}
    />
  )}

  {clientLogoData.length > 0 && (
    <ClientLogos heading="Confían en nosotros" logos={clientLogoData} speed="normal" />
  )}

  <CtaBanner
    eyebrow="¿Tienes un proyecto en mente?"
    title="Hablemos de tu obra"
    subtitle="Cuéntanos qué necesitas y te respondemos en menos de 24 horas con una propuesta inicial."
    primaryCta={{ label: t.common.requestQuote, href: `/${locale}/presupuesto/` }}
    secondaryCta={{
      label: t.common.chatWhatsApp,
      href: 'https://wa.me/34655634800',
      variant: 'whatsapp',
    }}
    variant="band"
  />
</BaseLayout>

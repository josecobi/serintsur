---
/*
  Projects index page (Spanish).

  Designer pass: wraps Backend's ProjectFilter island in BaseLayout + a hero
  band. The `<ProjectFilter />` mount survives as-is; Designer adds external
  class hooks (`.project-filter-*`) via global.css retargeting if needed.
*/
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import SectionHeading from '~/components/ui/SectionHeading.astro';
import CtaBanner from '~/components/sections/CtaBanner.astro';
import ProjectFilter from '~/components/project-filter/ProjectFilter';
import { projectsToCardData } from '~/components/project-filter/mapper';
import { getStrings } from '~/lib/i18n';
import { getProjects } from '~/lib/sanity';

const locale = 'es';
const t = getStrings(locale);

let projects: Awaited<ReturnType<typeof getProjects>> = [];
try {
  projects = await getProjects();
} catch (error) {
  console.error('[proyectos] Failed to fetch projects from Sanity:', error);
}

const cards = projectsToCardData(projects, locale);
---

<BaseLayout
  title={`${t.nav.projects} — ${t.site.name}`}
  description={t.site.descriptionShort}
  lang={locale}
>
  <section class="bg-offwhite">
    <Container width="wide" padY="lg">
      <SectionHeading
        eyebrow="Portfolio"
        title={t.nav.projects}
        subtitle="Selección de obras entregadas en Cádiz, Málaga y Sevilla. Filtra por servicio, provincia o año para encontrar proyectos similares al tuyo."
        level="h1"
      />
    </Container>
  </section>

  <section class="bg-white project-filter-root">
    <Container width="wide" padY="lg">
      <ProjectFilter client:load projects={cards} language={locale} />
    </Container>
  </section>

  <CtaBanner
    eyebrow="¿Te inspira alguno?"
    title="Hagamos el tuyo"
    subtitle="Cada obra empieza con una conversación. Pide presupuesto sin compromiso."
    primaryCta={{ label: t.common.requestQuote, href: `/${locale}/presupuesto/` }}
    secondaryCta={{
      label: t.common.chatWhatsApp,
      href: 'https://wa.me/34655634800',
      variant: 'whatsapp',
    }}
    variant="card"
  />
</BaseLayout>

---
/*
  Project detail page (Spanish).

  Designer pass: wraps Backend's getProjectBySlug in BaseLayout and renders a
  cinematic hero + two-column body/meta + gallery grid. Service reference,
  PortableText body, and gallery are all from Sanity.
*/
import type { GetStaticPaths } from 'astro';

import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import Badge from '~/components/ui/Badge.astro';
import CtaBanner from '~/components/sections/CtaBanner.astro';
import { getStrings } from '~/lib/i18n';
import { renderPortableText } from '~/lib/portable-text';
import {
  getAllProjectSlugs,
  getProjectBySlug,
  pickLocale,
  urlForImage,
  type ServiceRef,
} from '~/lib/sanity';

export const getStaticPaths: GetStaticPaths = async () => {
  try {
    const slugs = await getAllProjectSlugs();
    return slugs.map((slug) => ({ params: { slug } }));
  } catch (error) {
    console.error('[proyectos/[slug]] getStaticPaths failed:', error);
    return [];
  }
};

const locale = 'es';
const t = getStrings(locale);
const { slug } = Astro.params;

if (!slug) return Astro.redirect(`/${locale}/proyectos/`);
const slugString = String(slug);

const project = await getProjectBySlug(slugString).catch((e) => {
  console.error('[proyectos/[slug]] fetch failed:', e);
  return null;
});

if (!project) return new Response('Not found', { status: 404 });

const title = pickLocale(project.title, locale) ?? '';
const description = pickLocale(project.description, locale);
const body = pickLocale(project.body, locale);
const bodyHtml = renderPortableText(body);

const mainImageUrl = project.mainImage
  ? urlForImage(project.mainImage).width(2000).url()
  : undefined;

const serviceRef = isServiceRef(project.service) ? project.service : undefined;
const serviceTitle = serviceRef ? pickLocale(serviceRef.title, locale) : undefined;

const metaTitle = pickLocale(project.seo?.metaTitle, locale) ?? title;
const metaDescription =
  pickLocale(project.seo?.metaDescription, locale) ?? description ?? t.site.descriptionShort;

const locationParts = [
  project.location?.city,
  project.location?.province && t.provinces[project.location.province],
].filter(Boolean);

function isServiceRef(value: unknown): value is ServiceRef {
  return typeof value === 'object' && value !== null && 'title' in value;
}
---

<BaseLayout
  title={`${metaTitle} — ${t.site.name}`}
  description={metaDescription}
  noindex={project.seo?.noIndex}
  lang={locale}
>
  <!-- Hero: full-bleed image w/ navy gradient -->
  <section class="relative isolate overflow-hidden bg-navy text-white">
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      {mainImageUrl ? (
        <img
          src={mainImageUrl}
          alt={project.mainImage?.alt ?? title}
          class="h-full w-full object-cover"
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
      ) : (
        <div class="h-full w-full bg-[radial-gradient(circle_at_70%_30%,theme(colors.navy-light)_0%,theme(colors.navy)_50%,theme(colors.navy-dark)_100%)]" />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-navy-dark/95 via-navy/70 to-navy/30"></div>
    </div>

    <Container width="wide" padY="xl">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 text-xs text-white/60">
          <li>
            <a href={`/${locale}/`} class="hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm">
              {t.nav.home}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href={`/${locale}/proyectos/`} class="hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm">
              {t.nav.projects}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li class="text-white/90">{title}</li>
        </ol>
      </nav>

      <div class="flex min-h-[60svh] flex-col justify-end gap-5 py-10 md:min-h-[520px] md:py-16">
        <div class="flex flex-wrap items-center gap-2">
          {serviceTitle && <Badge variant="orange" size="md">{serviceTitle}</Badge>}
          {project.status && (
            <Badge
              variant={project.status === 'completed' ? 'success' : project.status === 'in_progress' ? 'info' : 'neutral'}
              size="md"
            >
              {t.status[project.status]}
            </Badge>
          )}
        </div>
        <h1 class="font-display text-display font-bold text-white">{title}</h1>
        {description && (
          <p class="max-w-2xl text-lg leading-relaxed text-white/85 md:text-xl">
            {description}
          </p>
        )}
        {(locationParts.length > 0 || project.year) && (
          <div class="mt-2 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-white/70">
            {locationParts.length > 0 && (
              <span class="inline-flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                {locationParts.join(', ')}
              </span>
            )}
            {project.year && (
              <span class="inline-flex items-center gap-2 font-tech">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <path d="M16 2v4"/>
                  <path d="M8 2v4"/>
                  <path d="M3 10h18"/>
                </svg>
                {project.year}
              </span>
            )}
          </div>
        )}
      </div>
    </Container>
  </section>

  <!-- Body + metadata sidebar -->
  <section class="bg-white">
    <Container width="wide" padY="lg">
      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-8">
          {bodyHtml ? (
            <div
              class="prose max-w-none prose-headings:font-display prose-headings:text-navy prose-a:text-orange prose-a:no-underline prose-a:font-semibold hover:prose-a:underline prose-strong:text-navy prose-img:rounded-lg"
              set:html={bodyHtml}
            />
          ) : description ? (
            <p class="text-lg leading-relaxed text-sand-900">{description}</p>
          ) : null}
        </div>

        <aside class="lg:col-span-4">
          <div class="rounded-xl border border-sand-200 bg-offwhite p-6 lg:sticky lg:top-24">
            <h2 class="font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange">
              Ficha del proyecto
            </h2>
            <dl class="mt-5 space-y-4 text-sm">
              {serviceTitle && serviceRef && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-sand-500">{t.common.service}</dt>
                  <dd class="mt-1">
                    <a
                      href={`/${locale}/servicios/${serviceRef.slug.current}/`}
                      class="font-semibold text-navy underline decoration-orange decoration-2 underline-offset-4 transition-colors hover:text-orange focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm"
                    >
                      {serviceTitle}
                    </a>
                  </dd>
                </div>
              )}
              {project.client && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-sand-500">{t.common.client}</dt>
                  <dd class="mt-1 font-medium text-navy">{project.client}</dd>
                </div>
              )}
              {locationParts.length > 0 && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-sand-500">{t.common.location}</dt>
                  <dd class="mt-1 font-medium text-navy">{locationParts.join(', ')}</dd>
                </div>
              )}
              {project.year !== undefined && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-sand-500">{t.common.year}</dt>
                  <dd class="mt-1 font-medium text-navy font-tech">{project.year}</dd>
                </div>
              )}
              {project.area !== undefined && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-sand-500">{t.common.area}</dt>
                  <dd class="mt-1 font-medium text-navy"><span class="font-tech">{project.area}</span> m²</dd>
                </div>
              )}
              {project.duration && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-sand-500">{t.common.duration}</dt>
                  <dd class="mt-1 font-medium text-navy">{project.duration}</dd>
                </div>
              )}
              {project.status && (
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-sand-500">{t.common.status}</dt>
                  <dd class="mt-1">
                    <Badge
                      variant={project.status === 'completed' ? 'success' : project.status === 'in_progress' ? 'info' : 'neutral'}
                      size="sm"
                    >
                      {t.status[project.status]}
                    </Badge>
                  </dd>
                </div>
              )}
            </dl>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <!-- Gallery -->
  {project.gallery && project.gallery.length > 0 && (
    <section class="bg-offwhite">
      <Container width="wide" padY="lg">
        <div class="mb-10">
          <div class="mb-3 flex items-center gap-3">
            <span class="h-[3px] w-10 rounded-sm bg-orange" aria-hidden="true" />
            <span class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-orange">
              Galería
            </span>
          </div>
          <h2 class="font-display text-h2 font-bold text-navy">Imágenes del proyecto</h2>
        </div>
        <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {project.gallery.map((image, i) => {
            const url = urlForImage(image).width(1200).url();
            const captionIsFirst = i === 0;
            return (
              <li class:list={[captionIsFirst && 'sm:col-span-2 sm:row-span-2 lg:col-span-2 lg:row-span-2']}>
                <figure class="overflow-hidden rounded-lg bg-sand-100">
                  <img
                    src={url}
                    alt={image.alt ?? `${title} — ${i + 1}`}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition-transform duration-700 ease-out hover:scale-[1.02]"
                  />
                  {image.caption && (
                    <figcaption class="bg-white px-4 py-3 text-xs text-sand-700">
                      {image.caption}
                    </figcaption>
                  )}
                </figure>
              </li>
            );
          })}
        </ul>
      </Container>
    </section>
  )}

  <CtaBanner
    eyebrow="Proyectos como este"
    title="¿Tienes una obra similar en mente?"
    subtitle="Cuéntanos los detalles y te preparamos una propuesta inicial en 24 horas."
    primaryCta={{ label: t.common.requestQuote, href: `/${locale}/presupuesto/` }}
    secondaryCta={{
      label: t.common.chatWhatsApp,
      href: 'https://wa.me/34655634800',
      variant: 'whatsapp',
    }}
    variant="band"
  />
</BaseLayout>

---
// Project detail page (Spanish).
//
// One route per project, enumerated via `getAllProjectSlugs`. Renders hero,
// locale-resolved portable-text body, gallery, and a side panel of metadata.
// Backend-owned data wiring; Designer replaces the visual shell.

import type { GetStaticPaths } from 'astro';

import Chatbot from '~/components/chatbot/Chatbot';
import { getStrings } from '~/lib/i18n';
import { renderPortableText } from '~/lib/portable-text';
import {
  getAllProjectSlugs,
  getProjectBySlug,
  pickLocale,
  urlForImage,
  type ServiceRef,
} from '~/lib/sanity';
import '~/styles/global.css';

export const getStaticPaths: GetStaticPaths = async () => {
  try {
    const slugs = await getAllProjectSlugs();
    return slugs.map((slug) => ({ params: { slug } }));
  } catch (error) {
    console.error('[proyectos/[slug]] getStaticPaths failed:', error);
    return [];
  }
};

const locale = 'es';
const t = getStrings(locale);
const { slug } = Astro.params;

if (!slug) return Astro.redirect(`/${locale}/proyectos`);
const slugString = String(slug);

const project = await getProjectBySlug(slugString).catch((e) => {
  console.error('[proyectos/[slug]] fetch failed:', e);
  return null;
});

if (!project) return new Response('Not found', { status: 404 });

const title = pickLocale(project.title, locale) ?? '';
const description = pickLocale(project.description, locale);
const body = pickLocale(project.body, locale);
const bodyHtml = renderPortableText(body);

const mainImageUrl = project.mainImage
  ? urlForImage(project.mainImage).width(1600).url()
  : undefined;

// `service` may be a bare reference or a fully dereferenced object — getProjectBySlug
// expands it, but guard anyway for schema drift.
const serviceRef = isServiceRef(project.service) ? project.service : undefined;
const serviceTitle = serviceRef ? pickLocale(serviceRef.title, locale) : undefined;

const metaTitle = pickLocale(project.seo?.metaTitle, locale) ?? title;
const metaDescription =
  pickLocale(project.seo?.metaDescription, locale) ?? description ?? t.site.descriptionShort;

function isServiceRef(value: unknown): value is ServiceRef {
  return typeof value === 'object' && value !== null && 'title' in value;
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metaTitle} — {t.site.name}</title>
    <meta name="description" content={metaDescription} />
    {project.seo?.noIndex && <meta name="robots" content="noindex" />}
  </head>
  <body class="bg-white min-h-screen">
    <main class="project-root">
      <header class="project-hero max-w-3xl mx-auto px-4 py-8">
        <p class="text-sm text-gray-500 mb-1">
          <a href={`/${locale}/proyectos`} class="underline">{t.nav.projects}</a>
        </p>
        <h1 class="project-title text-3xl sm:text-4xl font-semibold">{title}</h1>
        {description && <p class="project-description mt-3 text-lg text-gray-700">{description}</p>}
      </header>

      {mainImageUrl && (
        <div class="project-hero-image max-w-5xl mx-auto px-4">
          <img
            src={mainImageUrl}
            alt={project.mainImage?.alt ?? title}
            class="w-full h-auto rounded-lg"
            loading="lazy"
          />
        </div>
      )}

      <div class="project-main max-w-5xl mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-8">
        <div class="project-content">
          {bodyHtml ? (
            <section
              class="project-body prose prose-sm sm:prose max-w-none"
              set:html={bodyHtml}
            />
          ) : (
            <p class="text-gray-500">—</p>
          )}
        </div>

        <aside class="project-meta border border-gray-200 rounded-lg p-4 text-sm self-start">
          <dl class="space-y-2">
            {serviceTitle && (
              <div class="project-meta-row">
                <dt class="text-gray-500">{t.common.service}</dt>
                <dd class="font-medium">
                  <a href={`/${locale}/servicios/${serviceRef?.slug.current}`} class="underline">
                    {serviceTitle}
                  </a>
                </dd>
              </div>
            )}
            {project.year !== undefined && (
              <div class="project-meta-row">
                <dt class="text-gray-500">{t.common.year}</dt>
                <dd class="font-medium">{project.year}</dd>
              </div>
            )}
            {project.location && (project.location.city || project.location.province) && (
              <div class="project-meta-row">
                <dt class="text-gray-500">{t.common.location}</dt>
                <dd class="font-medium">
                  {[project.location.city, project.location.province && t.provinces[project.location.province]]
                    .filter(Boolean)
                    .join(', ')}
                </dd>
              </div>
            )}
            {project.client && (
              <div class="project-meta-row">
                <dt class="text-gray-500">{t.common.client}</dt>
                <dd class="font-medium">{project.client}</dd>
              </div>
            )}
            {project.area !== undefined && (
              <div class="project-meta-row">
                <dt class="text-gray-500">{t.common.area}</dt>
                <dd class="font-medium">{project.area} m²</dd>
              </div>
            )}
            {project.duration && (
              <div class="project-meta-row">
                <dt class="text-gray-500">{t.common.duration}</dt>
                <dd class="font-medium">{project.duration}</dd>
              </div>
            )}
            {project.status && (
              <div class="project-meta-row">
                <dt class="text-gray-500">{t.common.status}</dt>
                <dd class="font-medium">{t.status[project.status]}</dd>
              </div>
            )}
          </dl>
        </aside>
      </div>

      {project.gallery && project.gallery.length > 0 && (
        <section class="project-gallery max-w-5xl mx-auto px-4 py-8 border-t border-gray-200">
          <h2 class="project-section-title text-xl font-semibold mb-4">Galería</h2>
          <ul class="project-gallery-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {project.gallery.map((image, i) => {
              const url = urlForImage(image).width(1200).url();
              return (
                <li class="project-gallery-item">
                  <img
                    src={url}
                    alt={image.alt ?? `${title} — ${i + 1}`}
                    loading="lazy"
                    class="w-full h-auto rounded-md"
                  />
                </li>
              );
            })}
          </ul>
        </section>
      )}
    </main>
    <Chatbot client:idle language={locale} />
  </body>
</html>

---
/*
  Services listing page (Spanish).

  Designer pass: wraps Backend's Sanity fetch in BaseLayout and renders service
  cards using design-system primitives. Sanity outage → friendly empty state.
*/
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import SectionHeading from '~/components/ui/SectionHeading.astro';
import CtaBanner from '~/components/sections/CtaBanner.astro';
import { getStrings } from '~/lib/i18n';
import { getActiveServices, pickLocale, urlForImage } from '~/lib/sanity';

const locale = 'es';
const t = getStrings(locale);

let services: Awaited<ReturnType<typeof getActiveServices>> = [];
try {
  services = await getActiveServices();
} catch (error) {
  console.error('[servicios] failed to fetch services:', error);
}
---

<BaseLayout
  title={`${t.nav.services} — ${t.site.name}`}
  description={t.site.descriptionShort}
  lang={locale}
>
  <!-- Page header band on offwhite -->
  <section class="bg-offwhite">
    <Container width="wide" padY="lg">
      <SectionHeading
        eyebrow="Servicios"
        title={t.nav.services}
        subtitle="Cubrimos todo el ciclo de la edificación: desde la rehabilitación de fachadas hasta la construcción de villas, pasando por reformas integrales y mantenimiento de edificios."
        level="h1"
      />
    </Container>
  </section>

  <section class="bg-white">
    <Container width="wide" padY="lg">
      {services.length === 0 ? (
        <div class="rounded-lg border border-sand-200 bg-sand-50 p-10 text-center">
          <p class="font-display text-lg font-semibold text-navy">
            Estamos preparando el catálogo de servicios.
          </p>
          <p class="mt-2 text-sm text-sand-700">
            Mientras tanto, puedes{' '}
            <a href={`/${locale}/contacto/`} class="font-semibold text-orange underline decoration-2 underline-offset-4 hover:text-orange-dark">
              contactarnos directamente
            </a>
            .
          </p>
        </div>
      ) : (
        <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((service) => {
            const title = pickLocale(service.title, locale) ?? '';
            const description = pickLocale(service.description, locale);
            const heroUrl = service.heroImage
              ? urlForImage(service.heroImage).width(900).url()
              : undefined;
            const href = `/${locale}/servicios/${service.slug.current}/`;
            return (
              <li>
                <a
                  href={href}
                  aria-label={`${title} — ${t.common.readMore}`}
                  class="group flex h-full flex-col overflow-hidden rounded-lg border border-sand-200 bg-white transition-all duration-300 ease-out hover:-translate-y-1 hover:border-navy hover:shadow-lg focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2"
                >
                  <div class="relative aspect-[4/3] overflow-hidden bg-sand-100">
                    {heroUrl ? (
                      <img
                        src={heroUrl}
                        alt={title}
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                      />
                    ) : (
                      <div class="flex h-full w-full items-center justify-center bg-navy/5">
                        <span class="font-display text-3xl font-bold text-navy/30">
                          {title.charAt(0)}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-1 flex-col p-6">
                    <h2 class="font-display text-xl font-semibold text-navy">
                      {title}
                    </h2>
                    {description && (
                      <p class="mt-3 flex-1 text-sm leading-relaxed text-sand-700">
                        {description}
                      </p>
                    )}
                    <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-navy transition-colors group-hover:text-orange">
                      {t.common.readMore}
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-1">
                        <path d="M5 12h14"/>
                        <path d="m12 5 7 7-7 7"/>
                      </svg>
                    </span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </Container>
  </section>

  <CtaBanner
    eyebrow="¿No encuentras tu servicio?"
    title="Cuéntanos tu proyecto"
    subtitle="Cada obra tiene matices. Escríbenos y te proponemos el mejor camino."
    primaryCta={{ label: t.common.requestQuote, href: `/${locale}/presupuesto/` }}
    secondaryCta={{
      label: t.common.chatWhatsApp,
      href: 'https://wa.me/34655634800',
      variant: 'whatsapp',
    }}
    variant="card"
  />
</BaseLayout>

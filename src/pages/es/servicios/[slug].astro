---
/*
  Service detail page (Spanish).

  Designer pass: wraps Backend's getServiceBySlug+getProjects in BaseLayout and
  renders body Portable Text + feature list + related projects in design-system
  styling. All text comes from Sanity; UI chrome from `t`.
*/
import type { GetStaticPaths } from 'astro';

import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import Button from '~/components/ui/Button.astro';
import Badge from '~/components/ui/Badge.astro';
import CtaBanner from '~/components/sections/CtaBanner.astro';
import { projectsToCardData } from '~/components/project-filter/mapper';
import { getStrings } from '~/lib/i18n';
import { renderPortableText } from '~/lib/portable-text';
import {
  getAllServiceSlugs,
  getProjects,
  getServiceBySlug,
  pickLocale,
  urlForImage,
} from '~/lib/sanity';

export const getStaticPaths: GetStaticPaths = async () => {
  try {
    const slugs = await getAllServiceSlugs();
    return slugs.map((slug) => ({ params: { slug } }));
  } catch (error) {
    console.error('[servicios/[slug]] getStaticPaths failed:', error);
    return [];
  }
};

const locale = 'es';
const t = getStrings(locale);
const { slug } = Astro.params;

if (!slug) return Astro.redirect(`/${locale}/servicios/`);
const slugString = String(slug);

const service = await getServiceBySlug(slugString).catch((e) => {
  console.error('[servicios/[slug]] fetch failed:', e);
  return null;
});

if (!service) return new Response('Not found', { status: 404 });

const projectsRaw = await getProjects({ serviceId: service._id }).catch((e) => {
  console.error('[servicios/[slug]] projects fetch failed:', e);
  return [];
});
const projects = projectsToCardData(projectsRaw, locale);

const title = pickLocale(service.title, locale) ?? '';
const description = pickLocale(service.description, locale);
const body = pickLocale(service.body, locale);
const bodyHtml = renderPortableText(body);
const heroUrl = service.heroImage
  ? urlForImage(service.heroImage).width(1920).url()
  : undefined;

const metaTitle = pickLocale(service.seo?.metaTitle, locale) ?? title;
const metaDescription =
  pickLocale(service.seo?.metaDescription, locale) ?? description ?? t.site.descriptionShort;
---

<BaseLayout
  title={`${metaTitle} — ${t.site.name}`}
  description={metaDescription}
  noindex={service.seo?.noIndex}
  lang={locale}
>
  <!-- Hero: navy with optional hero image overlay -->
  <section class="relative isolate overflow-hidden bg-navy text-white">
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      {heroUrl ? (
        <img
          src={heroUrl}
          alt={title}
          class="h-full w-full object-cover"
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
      ) : (
        <div class="h-full w-full bg-[radial-gradient(circle_at_70%_30%,theme(colors.navy-light)_0%,theme(colors.navy)_50%,theme(colors.navy-dark)_100%)]" />
      )}
      <div class="absolute inset-0 bg-gradient-to-r from-navy-dark/95 via-navy/75 to-navy/40 md:from-navy-dark/90 md:via-navy/65 md:to-navy/20" />
    </div>

    <Container width="wide" padY="xl">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex flex-wrap items-center gap-2 text-xs text-white/60">
          <li>
            <a href={`/${locale}/`} class="hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm">
              {t.nav.home}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href={`/${locale}/servicios/`} class="hover:text-white focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 rounded-sm">
              {t.nav.services}
            </a>
          </li>
          <li aria-hidden="true">/</li>
          <li class="text-white/90">{title}</li>
        </ol>
      </nav>

      <div class="max-w-2xl py-8 md:py-12">
        <div class="mb-5 flex items-center gap-3">
          <span class="h-[3px] w-10 rounded-sm bg-orange" aria-hidden="true" />
          <span class="font-sans text-xs font-semibold uppercase tracking-[0.1em] text-orange-light">
            {t.nav.services}
          </span>
        </div>
        <h1 class="font-display text-h1 font-bold text-white">{title}</h1>
        {description && (
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/80">
            {description}
          </p>
        )}
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <Button variant="primary" size="lg" href={`/${locale}/presupuesto/`}>
            {t.common.requestQuote}
          </Button>
          <Button
            variant="outline"
            size="lg"
            href={`/${locale}/contacto/`}
            class="border-white/40 text-white hover:bg-white hover:text-navy"
          >
            {t.nav.contact}
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <!-- Body + features -->
  {(bodyHtml || (service.features && service.features.length > 0)) && (
    <section class="bg-white">
      <Container width="narrow" padY="lg">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
          {bodyHtml && (
            <div class="lg:col-span-8">
              <div
                class="prose max-w-none prose-headings:font-display prose-headings:text-navy prose-a:text-orange prose-a:no-underline prose-a:font-semibold hover:prose-a:underline prose-strong:text-navy prose-img:rounded-lg"
                set:html={bodyHtml}
              />
            </div>
          )}
          {service.features && service.features.length > 0 && (
            <aside class="lg:col-span-4">
              <div class="rounded-xl border border-sand-200 bg-offwhite p-6 lg:sticky lg:top-24">
                <h2 class="font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange">
                  Incluye
                </h2>
                <ul class="mt-5 space-y-3">
                  {service.features.map((feature) => {
                    const label = pickLocale(feature, locale);
                    return label ? (
                      <li class="flex items-start gap-3 text-sm text-sand-900">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-orange" aria-hidden="true">
                          <path d="M20 6 9 17l-5-5"/>
                        </svg>
                        <span>{label}</span>
                      </li>
                    ) : null;
                  })}
                </ul>
              </div>
            </aside>
          )}
        </div>
      </Container>
    </section>
  )}

  <!-- Related projects -->
  {projects.length > 0 && (
    <section class="bg-offwhite">
      <Container width="wide" padY="lg">
        <div class="mb-10 flex items-end justify-between gap-4">
          <div>
            <div class="mb-3 flex items-center gap-3">
              <span class="h-[3px] w-10 rounded-sm bg-orange" aria-hidden="true" />
              <span class="font-sans text-xs font-semibold uppercase tracking-[0.08em] text-orange">
                Obra relacionada
              </span>
            </div>
            <h2 class="font-display text-h2 font-bold text-navy">
              {t.nav.projects}
            </h2>
          </div>
          <a
            href={`/${locale}/proyectos/`}
            class="hidden shrink-0 items-center gap-2 rounded-sm text-sm font-semibold text-navy transition-colors hover:text-orange focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-2 md:inline-flex"
          >
            {t.common.seeAll}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>
        <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {projects.slice(0, 6).map((project) => (
            <li>
              <a
                href={`/${locale}/proyectos/${project.slug}/`}
                class="group block overflow-hidden rounded-lg bg-navy focus-visible:outline-2 focus-visible:outline-orange focus-visible:outline-offset-4"
                aria-label={project.title}
              >
                <div class="relative aspect-[4/3] overflow-hidden">
                  {project.imageUrl ? (
                    <img
                      src={project.imageUrl}
                      alt={project.imageAlt ?? project.title}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                    />
                  ) : (
                    <div class="h-full w-full bg-[linear-gradient(135deg,theme(colors.navy-light),theme(colors.navy-dark))]" />
                  )}
                  <div class="absolute inset-0 bg-gradient-to-t from-navy-dark/85 via-navy/20 to-transparent" aria-hidden="true"></div>
                  {project.province && (
                    <div class="absolute left-4 top-4">
                      <Badge variant="navy" size="sm">{project.province}</Badge>
                    </div>
                  )}
                  <div class="absolute inset-x-0 bottom-0 p-5">
                    <h3 class="font-display text-lg font-bold text-white">
                      {project.title}
                    </h3>
                    {(project.city || project.year) && (
                      <p class="mt-1 text-xs text-white/75">
                        {[project.city, project.year].filter(Boolean).join(' · ')}
                      </p>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </Container>
    </section>
  )}

  <CtaBanner
    eyebrow={`Servicio: ${title}`}
    title="¿Listo para empezar tu proyecto?"
    subtitle="Pide presupuesto sin compromiso o habla por WhatsApp con Jorge directamente."
    primaryCta={{ label: t.common.requestQuote, href: `/${locale}/presupuesto/` }}
    secondaryCta={{
      label: t.common.chatWhatsApp,
      href: 'https://wa.me/34655634800',
      variant: 'whatsapp',
    }}
    variant="band"
  />
</BaseLayout>
